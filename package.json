{
  "name": "@aman_asmuei/akit",
  "version": "0.3.0",
  "description": "The portable capability layer for AI companions — give any AI tools that work everywhere",
  "type": "module",
  "bin": {
    "akit": "./bin/akit.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "ai",
    "llm",
    "tools",
    "mcp",
    "capabilities",
    "cli",
    "acore"
  ],
  "author": "Aman Asmuei",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/amanasmuei/akit.git"
  },
  "dependencies": {
    "@clack/prompts": "^0.9.1",
    "commander": "^13.1.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
